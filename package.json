{
    "name":  "flip",
    "main":  "expo-router/entry",
    "version":  "1.0.0",
    "scripts":  {
                    "postinstall":  "node ./scripts/patch-foojay-gradle.js \u0026\u0026 node ./scripts/patch-android-node.js",
                    "start":  "expo start --dev-client --lan --port 8081",
                    "start:clear":  "expo start --dev-client --lan --port 8081 --clear",
                    "start:lan":  "expo start --dev-client --lan --port 8081",
                    "start:tunnel":  "expo start --dev-client --tunnel",
                    "reset-project":  "node ./scripts/reset-project.js",
                    "android":  "node ./scripts/android-build.js",
                    "android:build":  "node ./scripts/android-build.js",
                    "android:gradle":  "node ./scripts/android-build.js",
                    "android:prebuild":  "expo prebuild --platform android \u0026\u0026 node ./scripts/patch-android-node.js",
                    "android:dev":  "node ./scripts/android-build.js",
                    "android:dev:setup":  "expo prebuild --platform android \u0026\u0026 node ./scripts/android-build.js",
                    "ios":  "expo run:ios",
                    "web":  "expo start --web",
                    "web:oauth-metadata":  "node ./scripts/sync-oauth-metadata.js",
                    "web:export":  "node ./scripts/sync-oauth-metadata.js \u0026\u0026 expo export --platform web \u0026\u0026 node ./scripts/sync-oauth-metadata.js -- --dist",
                    "web:serve":  "node server.js",
                    "lint":  "expo lint",
                    "dev:connect":  "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/dev-connect.ps1",
                    "dev:connect:only":  "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/dev-connect.ps1 -ConnectOnly",
                    "dev:connect:reload":  "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/dev-connect.ps1 -ConnectOnly -Reload",
                    "dev:connect:reconnect":  "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/dev-connect.ps1 -Reconnect",
                    "android:reinstall":  "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/android-reinstall.ps1",
                    "dev:connect:restart":  "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/dev-connect.ps1 -RestartMetro",
                    "dev:connect:reset":  "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/dev-connect.ps1 -Reset",
                    "flip:dev":  "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/Start-FlipDev.ps1",
                    "beta:build":  "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/Start-FlipBeta.ps1",
                    "flip:beta":  "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/Start-FlipBeta.ps1",
                    "start:localhost":  "expo start --dev-client --localhost --port 8081",
                    "start:localhost:clear":  "expo start --dev-client --localhost --port 8081 --clear"
                },
    "dependencies":  {
