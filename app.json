{
    "expo": {
        "name": "Flip",
        "slug": "flip",
        "version": "1.0.2",
        "orientation": "portrait",
        "icon": "./assets/images/icon.png",
        "scheme": ["flip", "app.flip", "net.jsdelivr.cdn"],
        "userInterfaceStyle": "automatic",
        "ios": {
            "usesAppleSignIn": true,
            "supportsTablet": false,
            "bundleIdentifier": "social.flip.app",
            "infoPlist": {
                "NSCameraUsageDescription": "Flip needs camera access to record short videos with CameraX (1080p60) on Android and the native camera on iOS.",
                "NSMicrophoneUsageDescription": "Flip needs microphone access to record audio for your videos.",
                "NSPhotoLibraryAddUsageDescription": "Loops saves videos to your photo library when you download content you want to keep or save videos you've created in the app. This allows you to keep a local copy of your content",
                "NSPhotoLibraryUsageDescription": "Loops needs access to your photos and videos so you can select and upload videos from your library to share with the community."
            }
        },
        "android": {
            "adaptiveIcon": {
                "backgroundColor": "#000000",
                "foregroundImage": "./assets/images/android-icon-foreground.png",
                "backgroundImage": "./assets/images/android-icon-background.png",
                "monochromeImage": "./assets/images/android-icon-monochrome.png"
            },
            "edgeToEdgeEnabled": true,
            "navigationBar": {
                "backgroundColor": "#000000",
                "barStyle": "light-content"
            },
            "softwareKeyboardLayoutMode": "resize",
            "predictiveBackGestureEnabled": false,
            "package": "social.flip.app",
            "permissions": [
                "android.permission.READ_EXTERNAL_STORAGE",
                "android.permission.WRITE_EXTERNAL_STORAGE",
                "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
                "android.permission.ACCESS_MEDIA_LOCATION",
                "android.permission.READ_MEDIA_AUDIO",
                "android.permission.READ_MEDIA_IMAGES",
                "android.permission.READ_MEDIA_VIDEO",
                "android.permission.CAMERA",
                "android.permission.RECORD_AUDIO"
            ]
        },
        "web": {
            "output": "single",
            "favicon": "./assets/images/favicon.png"
        },
        "plugins": [
            "expo-dev-client",
            "expo-router",
            [
                "expo-splash-screen",
                {
                    "image": "./assets/images/splash-icon.png",
                    "imageWidth": 200,
                    "resizeMode": "contain",
                    "backgroundColor": "#000000",
                    "dark": {
                        "image": "./assets/images/splash-icon-dark.png",
                        "backgroundColor": "#000000"
                    }
                }
            ],
            "expo-secure-store",
            "expo-web-browser",
            "expo-video",
            [
                "expo-media-library",
                {
                    "photosPermission": "Loops needs access to your photos and videos so you can select and upload videos from your library to share with the community.",
                    "savePhotosPermission": "Loops saves videos to your photo library when you download content you want to keep or save videos you've created in the app. This allows you to keep a local copy of your content.",
                    "isAccessMediaLocationEnabled": true,
                    "granularPermissions": ["audio", "photo", "video"]
                }
            ],
            [
                "react-native-vision-camera",
                {
                    "enableLocation": false,
                    "cameraPermissionText": "Flip needs camera access to record 1080p60 video using CameraX on Android.",
                    "enableMicrophonePermission": true,
                    "microphonePermissionText": "Flip needs microphone access to record audio with your videos."
                }
            ],
            "react-native-compressor",
            "expo-apple-authentication",
            "expo-font",
            "expo-image",
            "expo-status-bar"
        ],
        "experiments": {
            "typedRoutes": true,
            "reactCompiler": true
        },
        "updates": {
            "enabled": false
        },
        "extra": {
            "router": {},
            "flipForYouFeed": "",
            "flipLocalFeed": "",
            "eas": {
                "projectId": ""
            }
        }
    }
}
