# Expo public env vars (safe to commit as examples — never commit real values).

# Keep React Native fetch for OAuth token exchange (see expo/expo#45909).
EXPO_PUBLIC_USE_RN_FETCH=1

# --- Phase 0: Flip staging PDS (invite-only) ---
# Set to the hostname of your local or hosted staging PDS.
# Leave blank to disable staging prefill on the sign-in screen.
# Example (local indigo PDS):  EXPO_PUBLIC_FLIP_STAGING_PDS_HOST=127.0.0.1:2583
# Example (hosted):            EXPO_PUBLIC_FLIP_STAGING_PDS_HOST=staging.flip.app
EXPO_PUBLIC_FLIP_STAGING_PDS_HOST=
