# Flip — example environment (copy to .env for local overrides)
# Never commit real secrets.

# Phase 0 staging PDS (dev-only Server field prefill in sign-in.tsx)
# Local indigo default: http://127.0.0.1:2583
# On device use LAN IP, e.g. http://192.168.1.42:2583
EXPO_PUBLIC_FLIP_STAGING_PDS_HOST=http://127.0.0.1:2583

# Handle suffix for operator scripts / docs (not used by app runtime yet)
EXPO_PUBLIC_FLIP_STAGING_HANDLE_DOMAIN=staging.flip.app

# Operator scripts (scripts/staging-pds/create-test-account.*)
# STAGING_PDS_HOST=http://127.0.0.1:2583
# STAGING_HANDLE=alice.staging.flip.app
# STAGING_EMAIL=alice@example.com
# STAGING_INVITE_CODE=
