# Expo 56 expo/fetch breaks @atproto/oauth-client identity/DID resolution on Android.
# Keep React Native fetch for OAuth token exchange (see expo/expo#45909).
EXPO_PUBLIC_USE_RN_FETCH=1

# Phase 0: Staging PDS for Flip-native signup spike (invite-only).
# Set this to your staging PDS hostname (e.g. staging.flip.app) to enable
# the Server field prefill in __DEV__ builds.
# EXPO_PUBLIC_FLIP_STAGING_PDS_HOST=staging.flip.app
